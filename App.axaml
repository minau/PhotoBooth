<!-- App.axaml -->
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Photobooth.Views"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.App">
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:MainView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CaptureViewModel}">
            <views:CaptureView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PhotostripViewModel}">
            <views:PhotostripView />
        </DataTemplate>
    </Application.DataTemplates>
    <Application.Styles>
        
        <!-- Ton style -->
        <Style Selector="Button.iconButton">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="CornerRadius" Value="40"/>
        </Style>

    </Application.Styles>
</Application>