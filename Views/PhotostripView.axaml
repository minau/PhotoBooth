<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.Views.PhotostripView"
             x:DataType="vm:PhotostripViewModel">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>   <!-- vignettes -->
            <ColumnDefinition Width="*"/>     <!-- preview -->
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT : VIGNETTES ================= -->
        <Border Grid.Column="0" Background="#111" Padding="8">
            <StackPanel Spacing="8">
                <Image Source="{Binding PhotostripFrame1}" Width="190" Height="150" Stretch="Uniform"/>
                <Image Source="{Binding PhotostripFrame2}" Width="190" Height="150" Stretch="Uniform"/>
                <Image Source="{Binding PhotostripFrame3}" Width="190" Height="150" Stretch="Uniform"/>
                <Image Source="{Binding PhotostripFrame4}" Width="190" Height="150" Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <!-- ================= RIGHT : PREVIEW + ACTIONS ================= -->
        <Grid Grid.Column="1" Margin="8" RowDefinitions="*,Auto">

            <!-- Zone image -->
            <Grid Grid.Row="0">
                <Image Source="{Binding Frame}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsCameraPreviewVisible}"/>

                <Image Source="{Binding FinalPreview}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsFinalPreviewVisible}"/>

                <!-- Countdown -->
                <Border Background="#66000000"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="16"
                        IsVisible="{Binding IsCounting}">
                    <TextBlock Text="{Binding RemainingSeconds}"
                               FontSize="72"
                               FontWeight="Bold"
                               Foreground="White"/>
                </Border>
            </Grid>

            <!-- ================= BARRE BAS ================= -->
            <Grid Grid.Row="1" Margin="0,12,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step -->
                <Border Background="#99000000"
                        CornerRadius="6"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Step, StringFormat='Photo {0}/4'}"
                               Foreground="White"/>
                </Border>

                <!-- Boutons centrés -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="16">

                    <Button Classes="iconButton"
                            Command="{Binding CancelCmd}">
                        <Image Width="42" Height="42"
                               Source="avares://Photobooth/Assets/icon_cancel.png"/>
                    </Button>

                    <Button Classes="iconButton"
                            Command="{Binding RestartCmd}">
                        <Image Width="42" Height="42"
                               Source="avares://Photobooth/Assets/icon_retry.png"/>
                    </Button>

                    <Button Classes="iconButton"
                            Command="{Binding PrintCmd}"
                            IsVisible="{Binding IsFinalPreviewVisible}"
                            IsEnabled="{Binding IsFinalPreviewVisible}">
                        <Image Width="42" Height="42"
                               Source="avares://Photobooth/Assets/icon_print.png"/>
                    </Button>

                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
