<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.Views.CaptureView"
             x:DataType="vm:CaptureViewModel">

    <Grid Margin="12" RowDefinitions="*,Auto">

        <!-- Zone image -->
        <Grid Grid.Row="0">
            <Image Source="{Binding Frame}"
                   Stretch="Uniform"
                   Height="520"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsCameraPreviewVisible}"/>

            <Image Source="{Binding FinalPreview}"
                   Stretch="Uniform"
                   Height="520"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsFinalPreviewVisible}"/>

            <Border Background="#66000000"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="16"
                    IsVisible="{Binding IsCounting}">
                <TextBlock Text="{Binding RemainingSeconds}"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Badge “figé” en haut à droite -->
            <Border Background="#99000000"
                    CornerRadius="6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="8"
                    Padding="6,2"
                    IsVisible="{Binding IsFrozen}">
                <TextBlock Text="Image figée"
                           Foreground="White"
                           FontSize="12"/>
            </Border>
        </Grid>

        <!-- Barre d’action -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center">
            <Button Classes="iconButton"
                    Command="{Binding StopCmd}">
                <Image Width="42"
                       Height="42"
                       Source="avares://Photobooth/Assets/icon_cancel.png"/>
            </Button>

            <Button Classes="iconButton"
                    Command="{Binding RestartCmd}">
                <Image Width="42"
                       Height="42"
                       Source="avares://Photobooth/Assets/icon_retry.png"/>
            </Button>

            <Button Classes="iconButton"
                    Command="{Binding PrintCmd}"
                    IsEnabled="{Binding IsFinalPreviewVisible}">
                <Image Width="42"
                       Height="42"
                       Source="avares://Photobooth/Assets/icon_print.png"/>
            </Button>
        </StackPanel>

    </Grid>
</UserControl>
