<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.Views.MainView"
             x:DataType="vm:MainViewModel">
    <StackPanel Margin="24" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="24" HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
            <Button Background="Transparent" Width="220" Height="140" Command="{Binding OptionACmd}" IsEnabled="{Binding IsCaptureAccessEnabled}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <Image Source="avares://Photobooth/Assets/icon_photo_simple_transparent.png"
                           Width="150" Height="72" Stretch="UniformToFill"/>
                </StackPanel>
            </Button>
            <Button Width="220" Height="140" Command="{Binding OptionBCmd}" IsEnabled="{Binding IsCaptureAccessEnabled}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <Image Source="avares://Photobooth/Assets/icon_photo_grid_transparent.png"
                           Width="150" Height="72" Stretch="UniformToFill"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <TextBlock Text="Impression en cours : retour capture temporairement bloqué."
                   HorizontalAlignment="Center"
                   IsVisible="{Binding IsPrintQueueBusy}"/>
    </StackPanel>
</UserControl>
