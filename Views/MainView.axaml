<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.Views.MainView"
             x:DataType="vm:MainViewModel">
    <StackPanel Margin="24" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="24" HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
            <Button Width="220" Height="140" Command="{Binding OptionACmd}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <Image Source="avares://Photobooth/Assets/classic.jpg"
                           Width="96" Height="72" Stretch="UniformToFill"/>
                    <TextBlock Text="Classique (1 photo)" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Width="220" Height="140" Command="{Binding OptionBCmd}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <Image Source="avares://Photobooth/Assets/strip.jpg"
                           Width="96" Height="72" Stretch="UniformToFill"/>
                    <TextBlock Text="Photostrip (4 photos)" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
