<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Photobooth.ViewModels"
             x:Class="Photobooth.Views.MainView"
             x:DataType="vm:MainViewModel">
    <StackPanel Margin="24" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="24" HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Width="220" Height="48" Content="Photostrip (4 photos)" Command="{Binding OptionACmd}"/>
            <Button Width="220" Height="48" Content="Grille 2×2"          Command="{Binding OptionBCmd}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
